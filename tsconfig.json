{
  "compilerOptions": {
    /* JavaScript Support */
    "allowJs": true,
    "checkJs": true,
    "noEmit": true /* Crucial: Do not compile/output files */,
    /* Strict Type-Checking Options */
    "strict": true /* Enable all strict type-checking options */,
    "noImplicitAny": true,
    "strictNullChecks": true,
    /* Environment */
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["types.d.ts", "packages/**/src/**/*", "packages/**/tests/**/*"],
  "exclude": ["node_modules", "**/node_modules", "**/dist", "**/assets"]
}
