{
  "$schema": "https://declarative-dom.org/schema/v1",
  "$id": "TodoApp",
  "$handlers": "./todo-app.js",
  "$defs": {
    "$items": {
      "type": "array",
      "default": [
        {
          "id": 1,
          "text": "Learn DDOM",
          "done": false
        },
        {
          "id": 2,
          "text": "Build something reactive",
          "done": false
        }
      ],
      "signal": true,
      "description": "Array of todo items: { id, text, done }"
    },
    "$remaining": {
      "$compute": "count($items[done = false])",
      "$deps": [
        "#/$defs/$items"
      ],
      "type": "integer",
      "signal": true,
      "description": "Number of incomplete items"
    },
    "$remainingLabel": {
      "$compute": "$string($remaining) & ' item' & ($remaining = 1 ? '' : 's') & ' left'",
      "$deps": [
        "#/$defs/$remaining"
      ],
      "type": "string",
      "signal": true
    },
    "addItem": {
      "$handler": true
    },
    "toggleItem": {
      "$handler": true
    },
    "clearDone": {
      "$handler": true
    }
  },
  "tagName": "todo-app",
  "style": {
    "display": "block",
    "fontFamily": "system-ui, sans-serif",
    "maxWidth": "480px",
    "margin": "2rem auto",
    "padding": "0"
  },
  "children": [
    {
      "tagName": "header",
      "style": {
        "padding": "1.5rem 1.5rem 0",
        "borderRadius": "8px 8px 0 0",
        "backgroundColor": "#007bff"
      },
      "children": [
        {
          "tagName": "h1",
          "textContent": "todos",
          "style": {
            "margin": "0 0 0.75rem",
            "fontSize": "2.5rem",
            "fontWeight": "100",
            "color": "rgba(255,255,255,0.7)",
            "letterSpacing": "-1px"
          }
        },
        {
          "tagName": "div",
          "style": {
            "display": "flex",
            "gap": "0.5rem",
            "paddingBottom": "1.5rem"
          },
          "children": [
            {
              "tagName": "input",
              "id": "new-todo",
              "attributes": {
                "type": "text",
                "placeholder": "What needs to be done?"
              },
              "style": {
                "flex": "1",
                "padding": "0.75rem 1rem",
                "fontSize": "1.1rem",
                "border": "none",
                "borderRadius": "5px",
                "outline": "none"
              },
              "onkeydown": {
                "$ref": "#/$defs/addItem"
              }
            }
          ]
        }
      ]
    },
    {
      "tagName": "ul",
      "style": {
        "listStyle": "none",
        "padding": "0",
        "margin": "0",
        "backgroundColor": "white",
        "border": "1px solid #e6e6e6",
        "borderTop": "none"
      },
      "children": {
        "$prototype": "Array",
        "items": {
          "$ref": "#/$defs/$items"
        },
        "map": {
          "tagName": "li",
          "$todoItem": {
            "$ref": "$map/item"
          },
          "$todoIndex": {
            "$ref": "$map/index"
          },
          "$toggleItem": {
            "$ref": "#/$defs/toggleItem"
          },
          "style": {
            "display": "flex",
            "alignItems": "center",
            "padding": "0.85rem 1.25rem",
            "borderBottom": "1px solid #ededed",
            ":last-child": {
              "borderBottom": "none"
            }
          },
          "children": [
            {
              "tagName": "input",
              "attributes": {
                "type": "checkbox"
              },
              "onclick": {
                "$ref": "#/$defs/toggleItem"
              },
              "style": {
                "width": "1.1rem",
                "height": "1.1rem",
                "marginRight": "0.85rem",
                "cursor": "pointer",
                "accentColor": "#007bff"
              }
            },
            {
              "tagName": "span",
              "textContent": {
                "$ref": "$map/item/text"
              },
              "style": {
                "flex": "1",
                "fontSize": "1.1rem",
                "color": "#4d4d4d"
              }
            }
          ]
        }
      }
    },
    {
      "tagName": "footer",
      "style": {
        "display": "flex",
        "justifyContent": "space-between",
        "alignItems": "center",
        "padding": "0.85rem 1.25rem",
        "backgroundColor": "white",
        "borderRadius": "0 0 8px 8px",
        "border": "1px solid #e6e6e6",
        "borderTop": "none",
        "fontSize": "0.875rem",
        "color": "#777"
      },
      "children": [
        {
          "tagName": "span",
          "textContent": {
            "$ref": "#/$defs/$remainingLabel"
          }
        },
        {
          "tagName": "button",
          "textContent": "Clear completed",
          "onclick": {
            "$ref": "#/$defs/clearDone"
          },
          "style": {
            "padding": "0.25em 0.6em",
            "border": "1px solid #adb5bd",
            "borderRadius": "3px",
            "backgroundColor": "white",
            "cursor": "pointer",
            "fontSize": "0.8rem",
            "color": "#6c757d",
            ":hover": {
              "backgroundColor": "#f8f9fa"
            }
          }
        }
      ]
    }
  ]
}