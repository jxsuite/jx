{
  "compilerOptions": {
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "esnext",
    "allowJs": true
  },
  "include": ["packages/**/*"],
  "exclude": ["node_modules", "**/node_modules", "**/dist", "**/assets"]
}
