{
  "tagName": "div",
  "style": {
    "margin": "0",
    "padding": "0",
    "fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "color": "#1e293b",
    "lineHeight": "1.6",
    "minHeight": "100vh",
    "display": "flex",
    "flexDirection": "column"
  },
  "children": [
    {
      "tagName": "header",
      "style": {
        "backgroundColor": "#0f172a",
        "padding": "0.875rem clamp(1rem, 3vw, 2rem)"
      },
      "children": [
        {
          "tagName": "nav",
          "style": {
            "maxWidth": "1200px",
            "margin": "0 auto",
            "display": "flex",
            "alignItems": "center",
            "justifyContent": "space-between"
          },
          "children": [
            {
              "tagName": "a",
              "attributes": { "href": "/" },
              "style": {
                "color": "white",
                "textDecoration": "none",
                "fontWeight": "700",
                "fontSize": "1.125rem",
                "letterSpacing": "-0.02em",
                "display": "flex",
                "alignItems": "center",
                "gap": "0.5rem"
              },
              "children": [
                {
                  "tagName": "span",
                  "style": {
                    "backgroundColor": "#3b82f6",
                    "color": "white",
                    "padding": "0.125rem 0.4rem",
                    "borderRadius": "4px",
                    "fontSize": "0.75rem",
                    "fontFamily": "'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace",
                    "fontWeight": "700"
                  },
                  "children": ["JX"]
                },
                "Platform"
              ]
            },
            {
              "tagName": "div",
              "style": {
                "display": "flex",
                "alignItems": "center",
                "gap": "clamp(1rem, 2.5vw, 1.5rem)"
              },
              "children": [
                {
                  "tagName": "a",
                  "attributes": { "href": "/docs/getting-started" },
                  "style": {
                    "color": "#94a3b8",
                    "textDecoration": "none",
                    "fontSize": "0.875rem",
                    "fontWeight": "500"
                  },
                  "children": ["Docs"]
                },
                {
                  "tagName": "a",
                  "attributes": {
                    "href": "https://github.com/jxplatform/jx",
                    "target": "_blank",
                    "rel": "noopener noreferrer"
                  },
                  "style": {
                    "color": "#94a3b8",
                    "textDecoration": "none",
                    "fontSize": "0.875rem",
                    "fontWeight": "500"
                  },
                  "children": ["GitHub"]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "tagName": "main",
      "style": { "flex": "1" },
      "children": [{ "tagName": "slot" }]
    },
    {
      "tagName": "footer",
      "style": {
        "backgroundColor": "#0f172a",
        "color": "#64748b",
        "padding": "clamp(1.5rem, 3vw, 3rem) clamp(1rem, 3vw, 2rem)",
        "textAlign": "center",
        "fontSize": "0.875rem",
        "lineHeight": "1.8"
      },
      "children": [
        {
          "tagName": "div",
          "style": { "maxWidth": "1200px", "margin": "0 auto" },
          "children": [
            {
              "tagName": "p",
              "style": { "margin": "0 0 0.5rem" },
              "children": ["Built with JX Platform. JSON in, HTML out."]
            },
            {
              "tagName": "p",
              "style": { "margin": "0" },
              "children": [
                "MIT License  \u00b7  ",
                {
                  "tagName": "a",
                  "attributes": { "href": "https://github.com/jxplatform/jx" },
                  "style": { "color": "#3b82f6", "textDecoration": "none" },
                  "children": ["Source on GitHub"]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
