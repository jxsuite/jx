{
  "name": "JX Platform",
  "url": "https://jxplatform.net",
  "defaults": {
    "layout": "./layouts/base.json",
    "lang": "en"
  },
  "imports": {
    "MarkdownFile": "@jxplatform/parser/MarkdownFile.class.json",
    "MarkdownCollection": "@jxplatform/parser/MarkdownCollection.class.json"
  },
  "$head": [
    { "tagName": "link", "attributes": { "rel": "icon", "href": "/favicon.svg" } },
    { "tagName": "meta", "attributes": { "name": "generator", "content": "JX Platform" } }
  ],
  "$media": {
    "--sm": "(min-width: 640px)",
    "--md": "(min-width: 768px)",
    "--lg": "(min-width: 1024px)",
    "--xl": "(min-width: 1280px)"
  },
  "style": {
    "margin": "0",
    "padding": "0",
    "fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif"
  },
  "build": {
    "outDir": "./dist",
    "format": "directory",
    "trailingSlash": "always"
  }
}
