{
  "title": "${state.page.frontmatter.title}",
  "$head": [
    {
      "tagName": "meta",
      "attributes": { "name": "description", "content": "${state.page.frontmatter.description}" }
    }
  ],
  "state": {
    "page": {
      "$prototype": "MarkdownFile",
      "src": "../../content/pages/getting-started.md",
      "timing": "compiler"
    }
  },
  "children": [
    {
      "tagName": "article",
      "style": {
        "maxWidth": "800px",
        "margin": "0 auto",
        "padding": "clamp(2rem, 4vw, 3rem) clamp(1rem, 3vw, 2rem)"
      },
      "innerHTML": "${state.page.$body}"
    }
  ]
}
