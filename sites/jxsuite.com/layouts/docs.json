{
  "tagName": "div",
  "style": {
    "margin": "0",
    "padding": "0",
    "color": "var(--text-primary)",
    "lineHeight": "1.6",
    "minHeight": "100vh",
    "display": "flex",
    "flexDirection": "column"
  },
  "children": [
    {
      "tagName": "header",
      "style": {
        "position": "sticky",
        "top": "0",
        "zIndex": "100",
        "backgroundColor": "rgba(10, 10, 10, 0.8)",
        "backdropFilter": "blur(12px)",
        "borderBottom": "1px solid var(--border)",
        "padding": "0 clamp(1rem, 3vw, 2rem)"
      },
      "children": [
        {
          "tagName": "nav",
          "style": {
            "maxWidth": "var(--max-width)",
            "margin": "0 auto",
            "display": "flex",
            "alignItems": "center",
            "justifyContent": "space-between",
            "height": "3.5rem"
          },
          "children": [
            {
              "tagName": "a",
              "attributes": { "href": "/" },
              "style": {
                "color": "var(--text-primary)",
                "textDecoration": "none",
                "fontWeight": "700",
                "fontSize": "1.0625rem",
                "letterSpacing": "-0.02em",
                "display": "flex",
                "alignItems": "center",
                "gap": "0.5rem"
              },
              "children": [
                {
                  "tagName": "span",
                  "style": {
                    "backgroundColor": "var(--accent)",
                    "color": "white",
                    "padding": "0.125rem 0.375rem",
                    "borderRadius": "4px",
                    "fontSize": "0.6875rem",
                    "fontFamily": "var(--font-mono)",
                    "fontWeight": "700",
                    "lineHeight": "1.4"
                  },
                  "children": ["JX"]
                },
                "Suite"
              ]
            },
            {
              "tagName": "div",
              "style": {
                "display": "flex",
                "alignItems": "center",
                "gap": "clamp(1.25rem, 3vw, 2rem)"
              },
              "children": [
                {
                  "tagName": "a",
                  "attributes": { "href": "/docs/getting-started" },
                  "style": {
                    "color": "var(--text-primary)",
                    "textDecoration": "none",
                    "fontSize": "0.875rem",
                    "fontWeight": "500"
                  },
                  "children": ["Docs"]
                },
                {
                  "tagName": "a",
                  "attributes": { "href": "/docs/spec" },
                  "style": {
                    "color": "var(--text-secondary)",
                    "textDecoration": "none",
                    "fontSize": "0.875rem",
                    "fontWeight": "500"
                  },
                  "children": ["Spec"]
                },
                {
                  "tagName": "a",
                  "attributes": {
                    "href": "https://github.com/jxplatform/jx",
                    "target": "_blank",
                    "rel": "noopener noreferrer"
                  },
                  "style": {
                    "color": "var(--text-secondary)",
                    "textDecoration": "none",
                    "fontSize": "0.875rem",
                    "fontWeight": "500"
                  },
                  "children": ["GitHub"]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "tagName": "div",
      "style": {
        "flex": "1",
        "display": "flex",
        "maxWidth": "var(--max-width)",
        "margin": "0 auto",
        "width": "100%"
      },
      "children": [
        {
          "tagName": "aside",
          "style": {
            "width": "240px",
            "flexShrink": "0",
            "borderRight": "1px solid var(--border)",
            "position": "sticky",
            "top": "3.5rem",
            "height": "calc(100vh - 3.5rem)",
            "overflowY": "auto",
            "paddingRight": "0.5rem",
            "@(max-width: 767px)": { "display": "none" }
          },
          "children": [{ "$ref": "../components/docs-sidebar.json" }]
        },
        {
          "tagName": "main",
          "style": {
            "flex": "1",
            "minWidth": "0",
            "padding": "clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 3vw, 2.5rem)"
          },
          "children": [{ "tagName": "slot" }]
        }
      ]
    },
    {
      "tagName": "footer",
      "style": {
        "borderTop": "1px solid var(--border)",
        "color": "var(--text-muted)",
        "padding": "clamp(1.5rem, 3vw, 2rem) clamp(1rem, 3vw, 2rem)",
        "fontSize": "0.8125rem",
        "textAlign": "center"
      },
      "children": [
        {
          "tagName": "p",
          "style": { "margin": "0" },
          "children": ["Built with JX Suite. MIT License."]
        }
      ]
    }
  ]
}
