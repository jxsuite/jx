{
  "name": "Jx Example Site",
  "url": "https://example.com",
  "defaults": {
    "layout": "./layouts/base.json",
    "lang": "en"
  },
  "$head": [
    { "tagName": "link", "attributes": { "rel": "icon", "href": "/favicon.svg" } },
    { "tagName": "meta", "attributes": { "name": "generator", "content": "Jx" } }
  ],
  "style": {
    "fontFamily": "system-ui, sans-serif",
    "margin": "0",
    "padding": "0"
  },
  "collections": {
    "blog": {
      "source": "./blog/**/*.md",
      "schema": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "pubDate": { "type": "string", "format": "date" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "draft": { "type": "boolean", "default": false }
        },
        "required": ["title", "pubDate"]
      }
    }
  },
  "redirects": {
    "/old-about": "/about"
  },
  "build": {
    "outDir": "./dist",
    "format": "directory",
    "trailingSlash": "always"
  }
}
