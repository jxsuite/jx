{
  "tagName": "div",
  "style": {
    "padding": "2rem",
    "fontFamily": "system-ui, sans-serif",
    "--font-heading": "Georgia, 'Times New Roman', serif",
    "--font-body": "system-ui, -apple-system, sans-serif",
    "--font-mono": "'SF Mono', 'Fira Code', monospace",
    "--color-primary": "#0066cc"
  },
  "children": [
    { "tagName": "h1", "textContent": "Font Test" },
    { "tagName": "p", "textContent": "Testing font token picker.", "style": { "fontFamily": "var(--font-body)" } },
    { "tagName": "code", "textContent": "monospace test", "style": { "fontFamily": "var(--font-mono)" } }
  ]
}
