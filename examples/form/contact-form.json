{
  "$schema": "../../packages/schema/schema.json",
  "$id": "ContactForm",
  "state": {
    "name": { "type": "string", "default": "" },
    "email": { "type": "string", "default": "" },
    "message": { "type": "string", "default": "" },
    "submitted": { "type": "boolean", "default": false },
    "nameValid": {
      "$prototype": "Function",
      "body": "return state.name.trim().length >= 2;"
    },
    "emailValid": {
      "$prototype": "Function",
      "body": "const e = state.email; return e.includes('@') && e.includes('.') && e.length > 5;"
    },
    "messageValid": {
      "$prototype": "Function",
      "body": "return state.message.trim().length >= 10;"
    },
    "formValid": {
      "$prototype": "Function",
      "body": "return state.nameValid && state.emailValid && state.messageValid;"
    },
    "setName": {
      "$prototype": "Function",
      "parameters": ["event"],
      "body": "state.name = event.target.value;"
    },
    "setEmail": {
      "$prototype": "Function",
      "parameters": ["event"],
      "body": "state.email = event.target.value;"
    },
    "setMessage": {
      "$prototype": "Function",
      "parameters": ["event"],
      "body": "state.message = event.target.value;"
    },
    "submit": {
      "$prototype": "Function",
      "body": "if (!state.formValid) return; console.log('Form submitted:', { name: state.name, email: state.email, message: state.message }); state.submitted = true; state.reset();"
    },
    "reset": {
      "$prototype": "Function",
      "body": "state.name = ''; state.email = ''; state.message = ''; state.submitted = false;"
    }
  },
  "tagName": "contact-form",
  "style": {
    "display": "block",
    "maxWidth": "480px",
    "margin": "2rem auto",
    "padding": "2rem",
    "backgroundColor": "white",
    "borderRadius": "8px",
    "boxShadow": "0 4px 16px rgba(0,0,0,0.1)",
    "fontFamily": "system-ui, sans-serif"
  },
  "children": [
    {
      "tagName": "h2",
      "textContent": "Contact Us",
      "style": { "margin": "0 0 1.5em", "color": "#333", "fontSize": "1.5em" }
    },
    {
      "tagName": "div",
      "style": { "marginBottom": "1.25em" },
      "children": [
        {
          "tagName": "label",
          "textContent": "Name",
          "style": {
            "display": "block",
            "fontWeight": "600",
            "marginBottom": "0.35em",
            "color": "#555",
            "fontSize": "0.9em"
          }
        },
        {
          "tagName": "input",
          "value": { "$ref": "#/state/name" },
          "oninput": { "$ref": "#/state/setName" },
          "attributes": { "type": "text", "placeholder": "Your full name" },
          "style": {
            "width": "100%",
            "boxSizing": "border-box",
            "padding": "0.6em 0.75em",
            "fontSize": "1em",
            "border": "1.5px solid #ced4da",
            "borderRadius": "5px",
            "outline": "none",
            ":focus": { "borderColor": "#007bff" }
          }
        },
        {
          "tagName": "small",
          "textContent": "Name must be at least 2 characters.",
          "hidden": { "$ref": "#/state/nameValid" },
          "style": { "color": "#dc3545", "fontSize": "0.8em" }
        }
      ]
    },
    {
      "tagName": "div",
      "style": { "marginBottom": "1.25em" },
      "children": [
        {
          "tagName": "label",
          "textContent": "Email",
          "style": {
            "display": "block",
            "fontWeight": "600",
            "marginBottom": "0.35em",
            "color": "#555",
            "fontSize": "0.9em"
          }
        },
        {
          "tagName": "input",
          "value": { "$ref": "#/state/email" },
          "oninput": { "$ref": "#/state/setEmail" },
          "attributes": { "type": "email", "placeholder": "you@example.com" },
          "style": {
            "width": "100%",
            "boxSizing": "border-box",
            "padding": "0.6em 0.75em",
            "fontSize": "1em",
            "border": "1.5px solid #ced4da",
            "borderRadius": "5px",
            "outline": "none",
            ":focus": { "borderColor": "#007bff" }
          }
        },
        {
          "tagName": "small",
          "textContent": "Enter a valid email address.",
          "hidden": { "$ref": "#/state/emailValid" },
          "style": { "color": "#dc3545", "fontSize": "0.8em" }
        }
      ]
    },
    {
      "tagName": "div",
      "style": { "marginBottom": "1.5em" },
      "children": [
        {
          "tagName": "label",
          "textContent": "Message",
          "style": {
            "display": "block",
            "fontWeight": "600",
            "marginBottom": "0.35em",
            "color": "#555",
            "fontSize": "0.9em"
          }
        },
        {
          "tagName": "textarea",
          "textContent": { "$ref": "#/state/message" },
          "oninput": { "$ref": "#/state/setMessage" },
          "attributes": { "rows": "4", "placeholder": "Your message (min 10 characters)\u2026" },
          "style": {
            "width": "100%",
            "boxSizing": "border-box",
            "padding": "0.6em 0.75em",
            "fontSize": "1em",
            "border": "1.5px solid #ced4da",
            "borderRadius": "5px",
            "outline": "none",
            "resize": "vertical",
            ":focus": { "borderColor": "#007bff" }
          }
        },
        {
          "tagName": "small",
          "textContent": "Message must be at least 10 characters.",
          "hidden": { "$ref": "#/state/messageValid" },
          "style": { "color": "#dc3545", "fontSize": "0.8em" }
        }
      ]
    },
    {
      "tagName": "div",
      "style": { "display": "flex", "gap": "0.75em" },
      "children": [
        {
          "tagName": "button",
          "textContent": "Send Message",
          "onclick": { "$ref": "#/state/submit" },
          "style": {
            "flex": "1",
            "padding": "0.7em 1em",
            "fontSize": "1em",
            "backgroundColor": "#28a745",
            "color": "white",
            "border": "none",
            "borderRadius": "5px",
            "cursor": "pointer",
            "fontWeight": "600",
            ":hover": { "backgroundColor": "#218838" },
            ":disabled": { "backgroundColor": "#adb5bd", "cursor": "not-allowed" }
          }
        },
        {
          "tagName": "button",
          "textContent": "Reset",
          "onclick": { "$ref": "#/state/reset" },
          "style": {
            "padding": "0.7em 1.25em",
            "fontSize": "1em",
            "backgroundColor": "white",
            "color": "#6c757d",
            "border": "1px solid #ced4da",
            "borderRadius": "5px",
            "cursor": "pointer",
            ":hover": { "backgroundColor": "#f8f9fa" }
          }
        }
      ]
    },
    {
      "tagName": "div",
      "hidden": { "$ref": "#/state/submitted" },
      "style": {
        "marginTop": "1.25em",
        "padding": "0.85em 1em",
        "backgroundColor": "#d4edda",
        "border": "1px solid #c3e6cb",
        "borderRadius": "5px",
        "color": "#155724",
        "fontSize": "0.9em"
      },
      "textContent": "Awaiting submission\u2026"
    },
    {
      "tagName": "details",
      "style": {
        "marginTop": "1.5em",
        "padding": "0.75em 1em",
        "backgroundColor": "#f8f9fa",
        "borderRadius": "5px",
        "fontSize": "0.8em",
        "color": "#6c757d"
      },
      "children": [
        {
          "tagName": "summary",
          "textContent": "Live form state",
          "style": { "cursor": "pointer", "fontWeight": "600", "marginBottom": "0.5em" }
        },
        {
          "tagName": "div",
          "children": [
            {
              "tagName": "div",
              "children": [
                { "tagName": "strong", "textContent": "name: " },
                { "tagName": "span", "textContent": { "$ref": "#/state/name" } }
              ]
            },
            {
              "tagName": "div",
              "children": [
                { "tagName": "strong", "textContent": "email: " },
                { "tagName": "span", "textContent": { "$ref": "#/state/email" } }
              ]
            },
            {
              "tagName": "div",
              "children": [
                { "tagName": "strong", "textContent": "valid: " },
                { "tagName": "span", "textContent": { "$ref": "#/state/formValid" } }
              ]
            }
          ]
        }
      ]
    }
  ]
}
