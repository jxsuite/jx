{
  "$schema": "https://declarative-dom.org/schema/v1",
  "$id": "ExamplesIndex",
  "$defs": {
    "activeTab": { "type": "string", "default": "counter" },
    "selectTab": {
      "$prototype": "Function",
      "arguments": ["event"],
      "body": "const id = event.currentTarget.dataset.tab; if (id) $defs.activeTab = id;",
      "description": "Switch active example tab"
    }
  },
  "tagName": "div",
  "style": {
    "fontFamily": "system-ui, sans-serif",
    "display": "flex",
    "flexDirection": "column",
    "height": "100vh",
    "margin": "0",
    "overflow": "hidden",
    "background": "#fff"
  },
  "children": [
    {
      "tagName": "nav",
      "style": {
        "display": "flex",
        "alignItems": "stretch",
        "borderBottom": "1px solid #e0e0e0",
        "background": "#f5f5f5",
        "padding": "0 0.5rem",
        "flexShrink": "0"
      },
      "children": {
        "$prototype": "Array",
        "items": [
          { "id": "counter",    "label": "Counter"    },
          { "id": "computed",   "label": "Computed"   },
          { "id": "list",       "label": "List"       },
          { "id": "fetch",      "label": "Fetch"      },
          { "id": "switch",     "label": "Switch"     },
          { "id": "form",       "label": "Form"       },
          { "id": "responsive", "label": "Responsive" },
          { "id": "todo",       "label": "Todo"       }
        ],
        "map": {
          "tagName": "button",
          "textContent": "${$map.item.label}",
          "style": {
            "background": "none",
            "border": "none",
            "borderBottom": "2px solid transparent",
            "padding": "0.625rem 0.875rem",
            "cursor": "pointer",
            "fontSize": "0.8125rem",
            "fontWeight": "500",
            "color": "#555",
            "transition": "color 0.15s, border-color 0.15s",
            ":hover": {
              "color": "#111",
              "borderBottomColor": "#bbb"
            }
          },
          "attributes": { "data-tab": "${$map.item.id}" },
          "onclick": { "$ref": "#/$defs/selectTab" }
        }
      }
    },
    {
      "tagName": "div",
      "style": {
        "flex": "1",
        "overflow": "auto",
        "minHeight": "0"
      },
      "children": [{
        "$switch": { "$ref": "#/$defs/activeTab" },
        "cases": {
          "counter":    { "$ref": "./counter/counter.json" },
          "computed":   { "$ref": "./computed/user-card.json" },
          "list":       { "$ref": "./list/dynamic-list.json" },
          "fetch":      { "$ref": "./fetch/fetch-demo.json" },
          "switch":     { "$ref": "./switch/router.json" },
          "form":       { "$ref": "./form/contact-form.json" },
          "responsive": { "$ref": "./responsive/responsive-card.json" },
          "todo":       { "$ref": "./todo/todo-app.json" }
        }
      }]
    }
  ]
}
