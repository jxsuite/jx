{
  "name": "@declarative-dom/ddom",
  "version": "0.8.0",
  "description": "Declarative Document Object Model — JSON-native reactive web component runtime",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".":          "./ddom.js",
    "./effect":   "./effect.js",
    "./compiler": "./ddom-compiler.js",
    "./schema":   "./ddom-schema.js"
  },
  "scripts": {
    "dev":     "bun run server.js",
    "build":   "bun build ddom.js --outdir dist --target browser --sourcemap linked",
    "schema":  "bun run ddom-schema.js ddom-schema.json",
    "compile": "bun run ddom-compiler.js"
  },
  "files": [
    "ddom.js",
    "effect.js",
    "ddom-compiler.js",
    "ddom-schema.js",
    "examples/"
  ],
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.5",
    "jsonata": "^2.1.0",
    "signal-polyfill": "^0.2.2"
  }
}
