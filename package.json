{
  "name": "jx-platform",
  "version": "0.0.1",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jxsuite/jx.git"
  },
  "workspaces": [
    "packages/*",
    "examples"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run build:compiler && bun run build:runtime && bun run build:studio && bun run generate:schema",
    "build:compiler": "bun run --cwd packages/compiler build",
    "build:runtime": "bun run --cwd packages/runtime build",
    "build:studio": "bun run --cwd packages/studio build",
    "desktop": "bun run --cwd packages/desktop dev",
    "desktop:build": "bun run --cwd packages/desktop build",
    "desktop:release": "bun run --cwd packages/desktop build:release",
    "dev": "bun run server.js",
    "format": "oxfmt .",
    "generate:schema": "bun run --cwd packages/schema schema",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "prepare": "husky",
    "release": "release-it",
    "release:publish": "bun publish --cwd packages/compiler --access public && bun publish --cwd packages/parser --access public && bun publish --cwd packages/runtime --access public && bun publish --cwd packages/schema --access public && bun publish --cwd packages/server --access public && bun publish --cwd packages/studio --access public",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc",
    "upgrade": "bunx npm-check-updates -u && bun install && bun run --workspaces upgrade",
    "pack": "bun run --workspaces bun pm pack"
  },
  "dependencies": {},
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@release-it/bumper": "^7.0.5",
    "@release-it/conventional-changelog": "^10.0.6",
    "chrome-devtools-mcp": "^0.23.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "release-it": "^20.0.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.json": [
      "oxfmt"
    ]
  },
  "release-it": {
    "git": {
      "requireCleanWorkingDir": false
    },
    "github": {
      "release": true
    },
    "hooks": {
      "before:init": "bun test && bun run lint",
      "after:bump": "bun run build && bun run release:publish"
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/bumper": {
        "out": [
          "packages/compiler/package.json",
          "packages/parser/package.json",
          "packages/runtime/package.json",
          "packages/schema/package.json",
          "packages/server/package.json",
          "packages/studio/package.json"
        ]
      },
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  }
}
